  </div>
</header>

<nav>
  <div class="tab active" data-tab="intake">📝 New Intake</div>
  <div class="tab" data-tab="dashboard">📊 Dashboard</div>
  <div class="tab" data-tab="interviews">📋 Interviews</div>
  <div class="tab" data-tab="preemployment">✅ Pre-Employment</div>
  <div class="tab" data-tab="hired">🟢 Hired Staff</div>
</nav>

<main>

<!-- ══ INTAKE FORM ══ -->
<div class="panel active" id="panel-intake">
<div class="intake-wrap">
<div class="intake-card">
  <div class="intake-banner">
    <h2>New Applicant Intake</h2>
    <p>Complete all fields from the interview sheet — Tab 1</p>
  </div>
  <div class="intake-body">

    <div class="section-ttl">Contact Information</div>
    <div class="intake-grid">
      <div class="fg"><label>Full Name *</label><input id="i-name" placeholder="Jane Smith"></div>
      <div class="fg"><label>Phone *</label><input id="i-phone" placeholder="(631) 555-0100"></div>
      <div class="fg"><label>Email</label><input id="i-email" type="email" placeholder="jane@email.com"></div>
      <div class="fg"><label>Town / Location</label><input id="i-town" placeholder="Hempstead"></div>
    </div>

    <div class="section-ttl">Eligibility</div>
    <div class="intake-grid">
      <div class="fg"><label>Legal to Work in USA</label>
        <select id="i-legal"><option value="Yes">Yes</option><option value="No">No</option></select>
      </div>
      <div class="fg"><label>Valid HHA / PCA</label>
        <select id="i-hha"><option value="Yes">Yes</option><option value="No">No</option></select>
      </div>
      <div class="fg"><label>Can Drive</label>
        <select id="i-drive"><option value="Yes">Yes</option><option value="No">No</option></select>
      </div>
      <div class="fg"><label>Nassau County Availability</label>
        <select id="i-nassau"><option value="Yes">Yes</option><option value="No">No</option></select>
      </div>
    </div>

    <div class="section-ttl">Availability</div>
    <div class="fg">
      <label>Availability Type</label>
      <div class="avail-grid" id="intake-avail-cbs">
        <label class="avail-cb"><input type="checkbox" value="Hourly"><span>Hourly</span></label>
        <label class="avail-cb"><input type="checkbox" value="Full-Time"><span>Full-Time</span></label>
        <label class="avail-cb"><input type="checkbox" value="Live-in"><span>Live-in</span></label>
        <label class="avail-cb"><input type="checkbox" value="Overnight"><span>Overnight</span></label>
        <label class="avail-cb"><input type="checkbox" value="Per Diem"><span>Per Diem</span></label>
      </div>
    </div>
    <div class="fg" style="margin-top:12px;">
      <label>Days Available</label>
      <div class="days-grid" id="intake-days-cbs">
        <label class="day-cb"><input type="checkbox" value="Monday"><span>Mon</span></label>
        <label class="day-cb"><input type="checkbox" value="Tuesday"><span>Tue</span></label>
        <label class="day-cb"><input type="checkbox" value="Wednesday"><span>Wed</span></label>
        <label class="day-cb"><input type="checkbox" value="Thursday"><span>Thu</span></label>
        <label class="day-cb"><input type="checkbox" value="Friday"><span>Fri</span></label>
        <label class="day-cb"><input type="checkbox" value="Saturday"><span>Sat</span></label>
        <label class="day-cb"><input type="checkbox" value="Sunday"><span>Sun</span></label>
      </div>
    </div>

    <div class="section-ttl">Interview & Scheduling</div>
    <div class="intake-grid">
      <div class="fg"><label>Date Added</label><input id="i-date" type="date"></div>
      <div class="fg"><label>Status</label>
        <select id="i-status">
          <option value="Pending Orientation">Pending Orientation</option>
            <option value="Pending for In-Person Interview">Pending for In-Person Interview</option>
          <option value="Hired">Hired</option>
          <option value="No Show">No Show</option>
          <option value="DNP">DNP</option>
          <option value="Rescheduled">Rescheduled</option>
          <option value="Fired">Fired</option>
