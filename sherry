// ══════ FILTER / SORT INTERVIEWS ══════
function filterIntData() {
  const q = document.getElementById('int-q').value.toLowerCase();
  const st = document.getElementById('int-status').value;
  const av = document.getElementById('int-avail').value;
  const dr = document.getElementById('int-drive').value;
  const na = document.getElementById('int-nassau').value;
  return interviews.filter(r => {
    if (q && !['NAME','PHONE','TOWN','EMAIL'].some(k=>(r[k]||'').toLowerCase().includes(q))) return false;
    if (st && r.STATUS !== st) return false;
    if (av && !(r.AVAILABILITY||'').includes(av)) return false;
    if (dr && r['CAN DRIVE'] !== dr) return false;
    if (na && r['NASSAU COUNTY AVAILABILITY'] !== na) return false;
    return true;
  });
}
function sortArr(data, s) {
  return [...data].sort((a,b) => {
    const av=(a[s.col]||'').toString().toLowerCase(), bv=(b[s.col]||'').toString().toLowerCase();
    return av<bv?-s.dir:av>bv?s.dir:0;
  });
}
function sortInt(col) { intSort.dir = intSort.col===col?-intSort.dir:1; intSort.col=col; renderInt(); }
function sortPre(col) { preSort.dir = preSort.col===col?-preSort.dir:1; preSort.col=col; renderPre(); }

// ══════ RENDER INTERVIEWS ══════
function renderInt() {
  intFiltered = sortArr(filterIntData(), intSort);
  const total = intFiltered.length;
  const pages = Math.max(1, Math.ceil(total/PAGE));
  intPage = Math.min(intPage, pages);
  const slice = intFiltered.slice((intPage-1)*PAGE, intPage*PAGE);
  document.getElementById('int-count').textContent = `${total} records`;

  const tb = document.getElementById('int-tbody');
  if (!slice.length) {
    tb.innerHTML = '<tr><td colspan="12"><div class="empty"><div class="ico">🔍</div>No records found</div></td></tr>';
  } else {
    tb.innerHTML = slice.map((r, idx) => `
      <tr>
        <td class="nm" onclick="openIntDetail(${(intPage-1)*PAGE+idx})">${r.NAME||'—'}</td>
        <td>${r.DATE?r.DATE.slice(0,10):'—'}</td>
        <td>${r.PHONE||'—'}</td>
        <td>${r.TOWN||'—'}</td>
        <td style="max-width:140px;">${r.AVAILABILITY||'—'}</td>
        <td>${yn(r['NASSAU COUNTY AVAILABILITY'])}</td>
        <td>${yn(r['CAN DRIVE'])}</td>
        <td>${yn(r['VALID HHA/PCA'])}</td>
        <td>${badge(r.STATUS)}</td>
        <td style="max-width:140px;">${r['ORIENTATION DATE']||'—'}</td>
        <td>${r['SCHEDULED BY']||'—'}</td>
        <td><button class="btn btn-edit btn-sm" onclick="openIntEdit(${(intPage-1)*PAGE+idx})">✏️</button></td>
      </tr>`).join('');
  }
  renderPgn('int', intPage, pages, total);
}

// ══════ RENDER PRE-EMPLOYMENT ══════
function filterPreData() {
