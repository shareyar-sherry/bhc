function renderMonthChart() {
  const yearFilter = (document.getElementById('ch-month-year')||{value:'all'}).value;

  // Build monthly buckets
  const monthlyScheduled = {};
  const monthlyHired = {};

  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  interviews.forEach(r => {
    // Interview scheduled date — use DATE field (when they were logged/scheduled)
    const raw = r.DATE || r['INTERVIEW DATE'] || '';
    const d = new Date(raw);
    if (!isNaN(d.getTime()) && d.getFullYear() > 2018) {
      const yr = d.getFullYear();
      if (yearFilter !== 'all' && String(yr) !== yearFilter) return;
      const key = MONTHS[d.getMonth()] + ' ' + yr;
      monthlyScheduled[key] = (monthlyScheduled[key] || 0) + 1;
    }
  });

  // ALL people in Pre-Employment tab are hired.
  // Use column A (DATE) as hire date; fall back to ORIENTATION DATE if DATE is empty.
  preemployment.forEach(r => {
    const raw = (r.DATE || '').trim() || (r['ORIENTATION DATE'] || '').trim();
    if (!raw) return;
    const d = new Date(raw);
    if (!isNaN(d.getTime()) && d.getFullYear() > 2018) {
      const yr = d.getFullYear();
      if (yearFilter !== 'all' && String(yr) !== yearFilter) return;
      const key = MONTHS[d.getMonth()] + ' ' + yr;
      monthlyHired[key] = (monthlyHired[key] || 0) + 1;
    }
  });

  // Populate year dropdown
  const sel = document.getElementById('ch-month-year');
  if (sel) {
    const allKeys = [...new Set([...Object.keys(monthlyScheduled), ...Object.keys(monthlyHired)])];
    const years = [...new Set(allKeys.map(k => k.split(' ')[1]))].sort();
    const curVal = sel.value;
    sel.innerHTML = '<option value="all">All Years</option>' +
      years.map(y => `<option value="${y}" ${curVal===y?'selected':''}>${y}</option>`).join('');
  }

  // Build sorted month keys
  const allKeys = [...new Set([...Object.keys(monthlyScheduled), ...Object.keys(monthlyHired)])];
  allKeys.sort((a, b) => {
    const [am, ay] = a.split(' '); const [bm, by] = b.split(' ');
    return (parseInt(ay) - parseInt(by)) || (MONTHS.indexOf(am) - MONTHS.indexOf(bm));
  });

  if (allKeys.length === 0) {
    document.getElementById('ch-monthly').innerHTML = '<p style="color:#94a3b8;font-size:13px;padding:10px;">No data with valid dates found.</p>';
    return;
  }

  const maxVal = Math.max(...allKeys.map(k => Math.max(monthlyScheduled[k]||0, monthlyHired[k]||0)), 1);

  const rows = allKeys.map(k => {
    const s = monthlyScheduled[k] || 0;
    const h = monthlyHired[k] || 0;
    const sp = Math.round(s / maxVal * 100);
    const hp = Math.round(h / maxVal * 100);
    return `<div style="display:flex;align-items:center;gap:8px;margin-bottom:7px;min-width:420px;">
      <div style="width:72px;font-size:11px;color:#64748b;text-align:right;flex-shrink:0;">${k}</div>
      <div style="flex:1;display:flex;flex-direction:column;gap:3px;">
        <div style="display:flex;align-items:center;gap:6px;">
          <div style="height:14px;width:${sp}%;background:#1d5fa8;border-radius:3px;min-width:${s>0?'3px':'0'};transition:width .3s;"></div>
          <span style="font-size:11px;color:#1d5fa8;font-weight:600;">${s}</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
          <div style="height:14px;width:${hp}%;background:#1c7a52;border-radius:3px;min-width:${h>0?'3px':'0'};transition:width .3s;"></div>
          <span style="font-size:11px;color:#1c7a52;font-weight:600;">${h}</span>
        </div>
      </div>
    </div>`;
  }).join('');

  document.getElementById('ch-monthly').innerHTML = `<div style="padding:4px 0 2px;">${rows}</div>`;
}

function barChart(id, counts, colors) {
  const el = document.getElementById(id);
  const pal = ['#0d8a8a','#12b0b0','#1c7a52','#c97d14','#b83232','#7c3aed','#1d5fa8','#0f766e'];
  const sorted = Object.entries(counts).sort((a,b)=>b[1]-a[1]);
  const max = Math.max(...sorted.map(e=>e[1]), 1);
  el.innerHTML = sorted.map(([lbl, n], i) => {
    const pct = Math.round(n/max*100);
    const color = (colors&&colors[lbl]) || pal[i%pal.length];
    return `<div class="bar-row">
      <div class="bar-lbl" title="${lbl}">${lbl}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${pct}%;background:${color};">${pct>18?n:''}</div></div>
      <div class="bar-n">${pct<=18?n:''}</div>
    </div>`;
  }).join('');
}

