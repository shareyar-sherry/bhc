  </div>
</div>

<div id="app-content" style="display:none;">
<header>
  <div class="logo">Brookville <em>Homecare</em></div>
  <div style="display:flex;align-items:center;gap:10px;margin-left:auto;margin-right:16px;">
    <span id="user-email-display" style="font-size:12px;color:rgba(255,255,255,.85);"></span>
    <button onclick="doSignOut()" id="signout-btn" style="display:none;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.25);color:#fff;border-radius:6px;padding:3px 10px;font-size:11px;cursor:pointer;">Sign Out</button>
  </div>
  <div class="hstats">
    <div class="hs"><span class="hs-val" id="hs-total">—</span><span class="hs-lbl">Applicants</span></div>
