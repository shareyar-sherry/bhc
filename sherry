// ══════ HELPERS ══════
function badge(s) {
  const m = {'Hired':'hired','No Show':'noshow','DNP':'dnp','Pending Orientation':'pending','Pending for In-Person Interview':'pending','Rescheduled':'rescheduled','Fired':'fired'};
  return `<span class="bdg bdg-${m[s]||'def'}">${s||'—'}</span>`;
