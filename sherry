<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<script src="https://accounts.google.com/gsi/client" async defer></script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BHC Staffing — Brookville Homecare</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Playfair+Display:wght@600&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0c1b33;
  --navy2: #162640;
  --teal: #0d8a8a;
  --teal-glow: #12b0b0;
  --cream: #f4f1eb;
  --warm: #faf9f6;
  --gold: #c4882a;
  --red: #b83232;
  --green: #1c7a52;
  --amber: #c97d14;
  --blue: #1d5fa8;
  --slate: #3a4e65;
  --muted: #6e849e;
  --border: #dce3ed;
  --card: #ffffff;
  --shadow: 0 2px 12px rgba(12,27,51,0.08);
  --shadow-lg: 0 8px 32px rgba(12,27,51,0.14);
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }
body { font-family: 'Sora', sans-serif; background: var(--cream); color: var(--navy); min-height: 100vh; }

/* ── HEADER ── */
header {
  background: var(--navy);
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28px;
  position: sticky; top: 0; z-index: 200;
  box-shadow: 0 2px 16px rgba(0,0,0,0.22);
}
.logo { font-family: 'Playfair Display', serif; color: #fff; font-size: 1.18rem; letter-spacing: 0.01em; }
.logo em { color: var(--teal-glow); font-style: normal; }
.hstats { display: flex; gap: 22px; }
.hs { text-align:center; }
.hs-val { display:block; font-size:1rem; font-weight:700; color:#fff; line-height:1; }
.hs-lbl { font-size:0.63rem; text-transform:uppercase; letter-spacing:.07em; color:rgba(255,255,255,.5); }

/* ── TABS ── */
nav {
  background: var(--navy2);
  border-top: 1px solid rgba(255,255,255,.07);
  display: flex;
  padding: 0 28px;
  overflow-x: auto;
}
.tab {
  padding: 11px 18px;
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: rgba(255,255,255,.45);
  cursor: pointer;
  border-bottom: 3px solid transparent;
  transition: all .2s;
  white-space: nowrap;
  user-select: none;
}
.tab:hover { color: rgba(255,255,255,.8); }
.tab.active { color: var(--teal-glow); border-bottom-color: var(--teal-glow); }

/* ── MAIN ── */
main { padding: 26px 28px; max-width: 1700px; }
.panel { display:none; }
.panel.active { display:block; }

/* ── KPI ROW ── */
.kpi-row { display:grid; grid-template-columns:repeat(5,1fr); gap:14px; margin-bottom:24px; }
.kpi {
  background: var(--card);
  border-radius: 10px;
  padding: 18px 20px;
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
}
.kpi-lbl { font-size:.65rem; text-transform:uppercase; letter-spacing:.08em; color:var(--muted); font-weight:600; margin-bottom:7px; }
.kpi-val { font-family:'Playfair Display',serif; font-size:2rem; line-height:1; color:var(--navy); }
.kpi-sub { font-size:.7rem; color:var(--muted); margin-top:3px; }
.kpi.green .kpi-val { color:var(--green); }
.kpi.red .kpi-val { color:var(--red); }
.kpi.amber .kpi-val { color:var(--amber); }

/* ── CHARTS ── */
.charts-row { display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-bottom:24px; }
.chart-card { background:var(--card); border-radius:10px; padding:20px 22px; border:1px solid var(--border); box-shadow:var(--shadow); }
.chart-ttl { font-size:.66rem; text-transform:uppercase; letter-spacing:.08em; color:var(--muted); font-weight:700; margin-bottom:14px; }
.bar-chart { display:flex; flex-direction:column; gap:9px; }
.bar-row { display:flex; align-items:center; gap:10px; }
.bar-lbl { font-size:.75rem; color:var(--slate); width:115px; flex-shrink:0; text-align:right; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.bar-track { flex:1; background:#eef1f6; border-radius:4px; height:20px; overflow:hidden; }
.bar-fill { height:100%; border-radius:4px; display:flex; align-items:center; padding-left:7px; font-size:.68rem; font-weight:700; color:#fff; min-width:4px; }
.bar-n { font-size:.73rem; color:var(--muted); width:28px; text-align:right; flex-shrink:0; }

/* ── FILTERS ── */
.filters { display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-bottom:16px; }
.srch { position:relative; flex:1; min-width:180px; }
.srch input {
  width:100%; padding:8px 12px 8px 34px;
  border:1px solid var(--border); border-radius:7px;
  font-family:inherit; font-size:.82rem; background:#fff; color:var(--navy);
  outline:none; transition:border-color .2s;
}
.srch input:focus { border-color:var(--teal); }
.srch-ico { position:absolute; left:10px; top:50%; transform:translateY(-50%); font-size:.85rem; color:var(--muted); pointer-events:none; }
select.flt {
  padding:8px 11px; border:1px solid var(--border); border-radius:7px;
  font-family:inherit; font-size:.8rem; background:#fff; color:var(--navy);
  cursor:pointer; outline:none; transition:border-color .2s;
}
select.flt:focus { border-color:var(--teal); }
.btn-add {
  background:var(--teal); color:#fff; border:none;
  padding:8px 15px; border-radius:7px;
  font-family:inherit; font-size:.78rem; font-weight:700;
  cursor:pointer; display:flex; align-items:center; gap:5px; white-space:nowrap;
}
.btn-add:hover { background:var(--teal-glow); }

/* ── TABLE ── */
.tbl-wrap { background:var(--card); border-radius:10px; border:1px solid var(--border); overflow:hidden; box-shadow:var(--shadow); }
.tbl-head { display:flex; justify-content:space-between; align-items:center; padding:12px 18px; border-bottom:1px solid var(--border); background:var(--warm); }
.tbl-head h3 { font-size:.68rem; text-transform:uppercase; letter-spacing:.07em; color:var(--muted); font-weight:700; }
.tbl-head span { font-size:.76rem; color:var(--muted); }
.tbl-scroll { overflow-x:auto; }
table { width:100%; border-collapse:collapse; font-size:.8rem; }
th {
  background:#f0f4f9; padding:9px 12px;
  text-align:left; font-size:.65rem; text-transform:uppercase; letter-spacing:.06em;
  color:var(--muted); font-weight:700; white-space:nowrap;
  border-bottom:1px solid var(--border); cursor:pointer; user-select:none;
}
th:hover { color:var(--navy); }
td { padding:9px 12px; border-bottom:1px solid #f0f3f8; vertical-align:middle; color:var(--slate); max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
tr:last-child td { border-bottom:none; }
tr:hover td { background:#f7fafd; }
.nm { color:var(--navy); font-weight:600; cursor:pointer; }
.nm:hover { color:var(--teal); text-decoration:underline; }

/* ── BADGES ── */
.bdg { display:inline-block; padding:2px 8px; border-radius:20px; font-size:.68rem; font-weight:700; letter-spacing:.02em; white-space:nowrap; }
.bdg-hired { background:#d4f0e4; color:#145235; }
.bdg-noshow { background:#fde0e0; color:#7b1515; }
.bdg-dnp { background:#fef0d0; color:#7a4500; }
.bdg-pending { background:#dbeafe; color:#1a3a8c; }
.bdg-rescheduled { background:#ede9fe; color:#4a1d95; }
.bdg-fired { background:#fee2e2; color:#6b1a1a; }
.bdg-def { background:#e9ecef; color:#3d4f63; }
.yn-y { color:var(--green); font-weight:700; font-size:.78rem; }
.yn-n { color:var(--red); font-size:.78rem; }

/* ── PAGINATION ── */
.pgn { display:flex; justify-content:space-between; align-items:center; padding:11px 18px; border-top:1px solid var(--border); background:var(--warm); }
.pgn-info { font-size:.76rem; color:var(--muted); }
.pgn-btns { display:flex; gap:5px; }
.pgn-btn {
  width:30px; height:30px; display:flex; align-items:center; justify-content:center;
  border:1px solid var(--border); border-radius:6px; background:#fff;
  cursor:pointer; font-size:.76rem; color:var(--slate); transition:all .15s;
}
.pgn-btn:hover { border-color:var(--teal); color:var(--teal); }
.pgn-btn.on { background:var(--teal); color:#fff; border-color:var(--teal); }
.pgn-btn:disabled { opacity:.3; cursor:default; }

/* ══════════════════════════════
   MODAL — shared shell
══════════════════════════════ */
.overlay {
  display:none; position:fixed; inset:0;
  background:rgba(12,27,51,.6); z-index:600;
  align-items:center; justify-content:center; padding:16px;
}
.overlay.open { display:flex; }
.modal {
  background:#fff; border-radius:14px;
  width:700px; max-width:100%; max-height:92vh; overflow-y:auto;
  box-shadow:var(--shadow-lg);
  animation: popIn .18s ease;
}
@keyframes popIn { from { transform:scale(.96); opacity:0; } to { transform:scale(1); opacity:1; } }
.modal-hd {
  padding:18px 22px; border-bottom:1px solid var(--border);
  display:flex; justify-content:space-between; align-items:flex-start;
  position:sticky; top:0; background:#fff; z-index:10;
}
.modal-hd h2 { font-family:'Playfair Display',serif; font-size:1.25rem; color:var(--navy); }
.modal-hd .sub { font-size:.76rem; color:var(--muted); margin-top:3px; }
.modal-close { background:none; border:none; font-size:1.3rem; cursor:pointer; color:var(--muted); line-height:1; }
.modal-body { padding:20px 22px; }

/* ── DETAIL VIEW (read mode) ── */
.dg { display:grid; grid-template-columns:1fr 1fr; gap:13px; }
.di { display:flex; flex-direction:column; gap:3px; }
.di.full { grid-column:1/-1; }
.di-lbl { font-size:.63rem; text-transform:uppercase; letter-spacing:.07em; color:var(--muted); font-weight:700; }
.di-val { font-size:.86rem; color:var(--navy); }
.modal-actions { display:flex; gap:8px; margin-top:18px; padding-top:14px; border-top:1px solid var(--border); }

/* ── EDIT FORM inside modal ── */
.edit-form { display:none; }
.edit-form.show { display:block; }
.detail-view { display:block; }
.detail-view.hide { display:none; }

.fg { display:flex; flex-direction:column; gap:5px; margin-bottom:12px; }
.fg label { font-size:.63rem; text-transform:uppercase; letter-spacing:.07em; color:var(--muted); font-weight:700; }
.fg input, .fg select, .fg textarea {
  padding:8px 11px; border:1px solid var(--border); border-radius:7px;
  font-family:inherit; font-size:.84rem; color:var(--navy); outline:none;
  transition:border-color .2s; background:#fff; width:100%;
}
.fg input:focus, .fg select:focus, .fg textarea:focus { border-color:var(--teal); }
.fg textarea { min-height:65px; resize:vertical; }
.fg-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.fg-grid .fg { margin-bottom:0; }
.fg-full { grid-column:1/-1; }

/* ── DAYS CHECKBOXES ── */
.days-grid { display:flex; flex-wrap:wrap; gap:7px; margin-top:4px; }
.day-cb { display:flex; align-items:center; gap:5px; cursor:pointer; }
.day-cb input[type=checkbox] { accent-color:var(--teal); width:14px; height:14px; cursor:pointer; }
.day-cb span { font-size:.8rem; color:var(--slate); user-select:none; }

/* ── AVAIL CHECKBOXES ── */
.avail-grid { display:flex; flex-wrap:wrap; gap:7px; margin-top:4px; }
.avail-cb { display:flex; align-items:center; gap:5px; cursor:pointer; }
.avail-cb input[type=checkbox] { accent-color:var(--teal); width:14px; height:14px; cursor:pointer; }
.avail-cb span { font-size:.8rem; color:var(--slate); user-select:none; }

/* ── INTAKE FORM ── */
.intake-wrap { max-width:760px; }
.intake-card { background:var(--card); border-radius:12px; border:1px solid var(--border); overflow:hidden; box-shadow:var(--shadow); }
.intake-banner {
  background: linear-gradient(135deg, var(--navy) 0%, #1a3a6b 100%);
  padding: 22px 28px;
  position: relative; overflow:hidden;
}
.intake-banner::after {
  content:''; position:absolute; right:-20px; top:-20px;
  width:120px; height:120px; border-radius:50%;
  background:rgba(13,138,138,.15);
}
.intake-banner h2 { font-family:'Playfair Display',serif; color:#fff; font-size:1.3rem; }
.intake-banner p { color:rgba(255,255,255,.6); font-size:.8rem; margin-top:4px; }
.intake-body { padding:24px 28px; }
.section-ttl { font-size:.65rem; text-transform:uppercase; letter-spacing:.09em; color:var(--teal); font-weight:700; margin-bottom:12px; margin-top:20px; padding-bottom:6px; border-bottom:2px solid #e8f4f4; }
.section-ttl:first-child { margin-top:0; }
.intake-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.intake-grid .fg { margin-bottom:0; }
.intake-grid .fg.span2 { grid-column:1/-1; }
.intake-actions { display:flex; gap:10px; justify-content:flex-end; margin-top:22px; padding-top:16px; border-top:1px solid var(--border); }

/* ── BUTTONS ── */
.btn { padding:9px 18px; border-radius:7px; font-family:inherit; font-size:.82rem; font-weight:600; cursor:pointer; transition:all .2s; border:none; }
.btn-primary { background:var(--teal); color:#fff; }
.btn-primary:hover { background:var(--teal-glow); }
.btn-secondary { background:#fff; color:var(--navy); border:1px solid var(--border); }
.btn-secondary:hover { border-color:var(--teal); color:var(--teal); }
.btn-danger { background:#fde8e8; color:var(--red); border:1px solid #f5c2c2; }
.btn-danger:hover { background:#fbd0d0; }
.btn-sm { padding:6px 12px; font-size:.75rem; }
.btn-edit { background:var(--navy); color:#fff; }
.btn-edit:hover { background:var(--navy2); }

/* ── TOAST ── */
#toast {
  position:fixed; bottom:24px; right:24px; z-index:999;
  background:var(--navy); color:#fff;
  padding:11px 18px; border-radius:8px;
  font-size:.82rem; font-weight:500;
  box-shadow:var(--shadow-lg);
  transform:translateY(80px); opacity:0;
  transition:all .3s ease;
  pointer-events:none;
}
#toast.show { transform:translateY(0); opacity:1; }
#toast.success { background:var(--green); }
#toast.error { background:var(--red); }

/* ── EMPTY ── */
.empty { text-align:center; padding:44px 20px; color:var(--muted); }
.empty .ico { font-size:2.2rem; margin-bottom:10px; }

@media(max-width:900px) {
  .kpi-row { grid-template-columns:repeat(3,1fr); }
  .charts-row { grid-template-columns:1fr; }
  main { padding:16px; }
  header,nav { padding-left:16px; padding-right:16px; }
  .intake-grid,.fg-grid { grid-template-columns:1fr; }
  .intake-grid .fg.span2 { grid-column:1; }
  .dg { grid-template-columns:1fr; }
  .di.full { grid-column:1; }
}

@media print {
  body * { visibility: hidden !important; }
  #print-dashboard-area, #print-dashboard-area * { visibility: visible !important; }
  #print-dashboard-area { position: absolute; top: 0; left: 0; width: 100%; padding: 20px; }
  .no-print { display: none !important; }
  header, nav { display: none !important; }
  @page { margin: 1cm; }
}
</style>
</head>
