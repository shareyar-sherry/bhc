// ══════ CSV EXPORT ══════
function exportCSV(which) {
  let data, filename;
  if (which === 'interviews') { data = interviews; filename = 'BHC_Interviews.csv'; }
  else if (which === 'interviews-filtered') { data = intFiltered; filename = 'BHC_Interviews_Filtered.csv'; }
  else if (which === 'preemployment') { data = preemployment; filename = 'BHC_PreEmployment.csv'; }
  else if (which === 'hired') { data = interviews.filter(r => r.STATUS === 'Hired'); filename = 'BHC_HiredStaff.csv'; }
  else return;

  if (!data || data.length === 0) { toast('No data to export.', 'error'); return; }

  const cols = ['NAME','PHONE','EMAIL','TOWN','STATUS','AVAILABILITY','DAYS AVAILABLE',
    'CAN DRIVE','NASSAU COUNTY AVAILABILITY','VALID HHA/PCA','LEGAL TO WORK IN USA',
    'INTERVIEW DATE','ORIENTATION DATE','SCHEDULED BY','DATE','COMMENTS'];

  const esc = v => {
    if (v == null) return '';
    const s = String(v).replace(/"/g, '""');
    return (s.includes(',') || s.includes('"') || s.includes('\n')) ? '"' + s + '"' : s;
  };

  const csv = [cols.map(esc).join(','), ...data.map(r => cols.map(c => esc(r[c])).join(','))].join('\r\n');
  const blob = new Blob([csv], {type: 'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  URL.revokeObjectURL(url);
  toast('Exported ' + data.length + ' records to ' + filename);
}

