// ══════ PAGINATION ══════
function renderPgn(w, page, pages, total) {
  const s = (page-1)*PAGE+1, e = Math.min(page*PAGE,total);
  let h = `<span class="pgn-info">Showing ${s}–${e} of ${total}</span><div class="pgn-btns">`;
  h += `<button class="pgn-btn" ${page<=1?'disabled':''} onclick="goPage('${w}',${page-1})">‹</button>`;
  let ps = Math.max(1,page-2), pe = Math.min(pages,ps+4);
  if (pe-ps<4) ps=Math.max(1,pe-4);
  for (let p=ps;p<=pe;p++) h += `<button class="pgn-btn ${p===page?'on':''}" onclick="goPage('${w}',${p})">${p}</button>`;
  h += `<button class="pgn-btn" ${page>=pages?'disabled':''} onclick="goPage('${w}',${page+1})">›</button></div>`;
  document.getElementById(w+'-pgn').innerHTML = h;
}
function goPage(w,p) { if(w==='int'){intPage=p;renderInt();}else{prePage=p;renderPre();} }

