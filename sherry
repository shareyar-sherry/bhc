    auto_select: false
  });
  google.accounts.id.renderButton(
    document.getElementById('google-signin-btn'),
    {theme: 'outline', size: 'large', width: 280, text: 'signin_with'}
  );
}

// Check existing session
(function() {
  var saved = sessionStorage.getItem('bhc_user');
  if (saved) {
    bootApp(saved);
  } else {
    // Wait for Google GSI to load then init
    var tries = 0;
    var interval = setInterval(function() {
      tries++;
      if (window.google && google.accounts) {
        clearInterval(interval);
        initGoogleSignIn();
      } else if (tries > 20) {
        clearInterval(interval);
        document.getElementById('gate-error').textContent = 'Google Sign-In failed to load. Check your connection.';
      }
    }, 200);
  }
})();

// ══════ INIT ══════

// App boots via Google Sign-In above
</script>

