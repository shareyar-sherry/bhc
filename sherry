async function gsLoad(silent) {
  if (!silent) showSyncStatus('Loading data...', '#1d5fa8');
  try {
    var res = await fetch(SCRIPT_URL + '?action=getAll&t=' + Date.now());
    var data = await res.json();
    if (!data.ok) throw new Error(data.error);
    var intOpen = document.getElementById('int-modal').classList.contains('open');
    var preOpen = document.getElementById('pre-modal').classList.contains('open');
    if (silent && (intOpen || preOpen)) { showSyncStatus('New data available - close record to refresh', '#c97d14'); return; }
    interviews    = data.interviews.map(function(r,i)    { return Object.assign({}, r, {_id: r._id||i}); });
    preemployment = data.preemployment.map(function(r,i) { return Object.assign({}, r, {_id: r._id||(i+10000)}); });
    gsLoaded = true;
    saveToStorage();
    renderInt(); renderPre(); updateHStats();
    if (document.getElementById('panel-dashboard').classList.contains('active')) renderDash();
    lastSyncTime = new Date();
    showSyncStatus('Live - Synced ' + lastSyncTime.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}), '#1c7a52');
