  <div style="background:#fff;border-radius:20px;padding:48px 44px;width:380px;box-shadow:0 20px 60px rgba(0,0,0,.3);text-align:center;font-family:Inter,sans-serif;">
    <div style="font-family:'Playfair Display',serif;font-size:1.8rem;color:#0f2952;font-weight:700;">Brookville</div>
    <div style="font-family:'Playfair Display',serif;font-size:1.8rem;color:#0d8a8a;font-style:italic;margin-top:-4px;">Homecare</div>
