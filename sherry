// ══════ DASHBOARD ══════
function renderDash() {
  const kpiYr = (document.getElementById('kpi-year')||{value:'all'}).value;
  const kpiMo = (document.getElementById('kpi-month')||{value:'all'}).value;
  const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];

  // Populate year dropdown once
  const kpiYrSel = document.getElementById('kpi-year');
  if (kpiYrSel && kpiYrSel.options.length <= 1) {
    const years = new Set();
    interviews.forEach(r => { const d = new Date(r.DATE||''); if (!isNaN(d.getTime()) && d.getFullYear()>2018) years.add(d.getFullYear()); });
    preemployment.forEach(r => { const raw=(r.DATE||'').trim()||(r['ORIENTATION DATE']||'').trim(); const d=new Date(raw); if(!isNaN(d.getTime())&&d.getFullYear()>2018) years.add(d.getFullYear()); });
    const cur = kpiYrSel.value;
    kpiYrSel.innerHTML = '<option value="all">All Years</option>' + [...years].sort().map(y=>`<option value="${y}" ${String(y)===cur?'selected':''}>${y}</option>`).join('');
  }

  // Filter helper for interviews by date
  function matchDate(r) {
    if (kpiYr === 'all' && kpiMo === 'all') return true;
    const d = new Date(r.DATE||'');
    if (isNaN(d.getTime())) return false;
    if (kpiYr !== 'all' && String(d.getFullYear()) !== kpiYr) return false;
    if (kpiMo !== 'all' && String(d.getMonth()) !== kpiMo) return false;
    return true;
  }

  // Filter helper for preemployment by date
  function matchPreDate(r) {
    if (kpiYr === 'all' && kpiMo === 'all') return true;
    const raw = (r.DATE||'').trim() || (r['ORIENTATION DATE']||'').trim();
    const d = new Date(raw);
    if (isNaN(d.getTime())) return false;
    if (kpiYr !== 'all' && String(d.getFullYear()) !== kpiYr) return false;
    if (kpiMo !== 'all' && String(d.getMonth()) !== kpiMo) return false;
    return true;
  }

  const filteredInt = interviews.filter(matchDate);
  const filteredPre = preemployment.filter(matchPreDate);

  const total = filteredInt.length;
  const hired = filteredInt.filter(r=>r.STATUS==='Hired').length;
  const noshow = filteredInt.filter(r=>r.STATUS==='No Show'||r.STATUS==='DNP').length;
  const pending = filteredInt.filter(r=>r.STATUS==='Pending Orientation').length;
  const hiredTotal = filteredPre.length;
  const rate = total ? Math.round(hiredTotal/total*100) : 0;

  document.getElementById('kpi-total').textContent = total;
  document.getElementById('kpi-hired').textContent = hired;
  document.getElementById('kpi-noshow').textContent = noshow;
  document.getElementById('kpi-pending').textContent = pending;
  document.getElementById('kpi-rate').textContent = rate+'%';

  // Update subtitles & filter label
  const isFiltered = kpiYr !== 'all' || kpiMo !== 'all';
  const label = [kpiMo !== 'all' ? MONTHS[parseInt(kpiMo)] : '', kpiYr !== 'all' ? kpiYr : ''].filter(Boolean).join(' ');
  const subLabel = isFiltered ? label : 'All time';
  ['kpi-total-sub','kpi-hired-sub'].forEach(id => { const el=document.getElementById(id); if(el) el.textContent = subLabel; });
  const fl = document.getElementById('kpi-filter-label');
  if (fl) fl.textContent = isFiltered ? `Showing: ${label}` : '';

  const statusC = {};
  interviews.forEach(r => { const s=r.STATUS||'Unknown'; statusC[s]=(statusC[s]||0)+1; });
  const statusColors = {'Hired':'#1c7a52','No Show':'#b83232','DNP':'#c97d14','Pending Orientation':'#1d5fa8','Pending for In-Person Interview':'#0891b2','Rescheduled':'#7c3aed','Fired':'#6b1a1a'};
  barChart('ch-status', statusC, statusColors);

  const availC = {};
  interviews.forEach(r => {
    (r.AVAILABILITY||'').split(',').forEach(a => { const k=a.trim(); if(k) availC[k]=(availC[k]||0)+1; });
  });
  barChart('ch-avail', availC, null);

  const locC = {};
  interviews.forEach(r => { const l=(r.TOWN||'').trim(); if(l) locC[l]=(locC[l]||0)+1; });
  const top8 = Object.fromEntries(Object.entries(locC).sort((a,b)=>b[1]-a[1]).slice(0,8));
  barChart('ch-loc', top8, null);

  const drC = {};
  interviews.forEach(r => { const d=r['CAN DRIVE']||'Unknown'; drC[d]=(drC[d]||0)+1; });
  barChart('ch-drive', drC, {'Yes':'#1c7a52','No':'#b83232','Unknown':'#94a3b8'});

